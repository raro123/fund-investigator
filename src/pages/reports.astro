---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/ui/Hero.astro';
import ReportCard from '../components/ReportCard.astro';
import { getCollection } from 'astro:content';
import { responsive } from '../lib/responsive';

const allReports = await getCollection('reports');
const sortedReports = allReports
  .filter(report => !report.id.startsWith('_'))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

// Category-only filter tabs (tags deferred until more reports exist)
const filterTabs = [
  { label: 'All Files', value: 'all' },
  { label: 'Fund Analysis', value: 'Fund Analysis' },
  { label: 'Comparisons', value: 'Category Comparison' },
  { label: 'Methodology', value: 'Methodology' },
];
---

<Layout title="Investigation Reports - Fund Investigator" description="Fact-based analysis of mutual funds and investment categories.">

  <!-- Single Hero section: clears fixed header, owns all vertical rhythm -->
  <Hero size="sm" background="dark" centered={false} containerClass="max-w-6xl mx-auto">

    <!-- Title block: centered -->
    <div class="text-center mb-10 md:mb-12">
      <h1 class:list={[responsive.h2Large, 'font-bold text-fi-ink-inv mb-6 break-words']}>
        The Investigation Archive
      </h1>
      <p class="text-body-md text-fi-muted-inv leading-relaxed max-w-2xl mx-auto">
        Fact-based analysis of mutual funds and investment categories. Evidence before opinion. No marketing fluff, just the raw data and our verdict.
      </p>
    </div>

    <!-- Filter tab strip + results count -->
    <div class="flex items-end gap-6 mb-10 overflow-x-auto pb-px">
      {filterTabs.map((tab, i) => (
        <button
          class:list={[
            'filter-btn whitespace-nowrap text-caption uppercase tracking-widest pb-2 border-b-2 transition-all duration-200 flex-shrink-0',
            i === 0
              ? 'text-fi-ink-inv border-fi-gold'
              : 'text-fi-muted-inv/50 border-transparent hover:text-fi-ink-inv',
          ]}
          data-filter={tab.value}
        >
          {tab.label}
        </button>
      ))}
      <span id="results-count" class="text-caption text-fi-muted-inv/50 uppercase tracking-widest ml-auto flex-shrink-0 pb-2">
        {sortedReports.length} Records Found
      </span>
    </div>

    <!-- Card grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" id="reports-grid">
      {sortedReports.map((report) => (
        <div
          class="report-item"
          data-category={report.data.category}
        >
          <ReportCard report={report} href={`/reports/${report.slug}`} />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden py-16 text-center">
      <p class="text-heading-sm font-semibold text-fi-ink-inv mb-2">No investigations in this category yet.</p>
      <p class="text-body-md text-fi-muted-inv">Check back soon — more are in progress.</p>
    </div>

  </Hero>

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.report-item');
    const emptyState = document.getElementById('empty-state');
    const resultsCount = document.getElementById('results-count');

    function updateCount(visible: number) {
      if (resultsCount) {
        resultsCount.textContent = `${visible} Record${visible !== 1 ? 's' : ''} Found`;
      }
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active tab underline
        buttons.forEach(b => {
          b.classList.remove('text-fi-ink-inv', 'border-fi-gold');
          b.classList.add('text-fi-muted-inv/50', 'border-transparent');
        });
        btn.classList.remove('text-fi-muted-inv/50', 'border-transparent');
        btn.classList.add('text-fi-ink-inv', 'border-fi-gold');

        const filter = btn.getAttribute('data-filter') ?? 'all';
        let visible = 0;

        items.forEach(item => {
          const match = filter === 'all' || item.getAttribute('data-category') === filter;
          item.classList.toggle('hidden', !match);
          if (match) visible++;
        });

        if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
        updateCount(visible);
      });
    });
  });
</script>
