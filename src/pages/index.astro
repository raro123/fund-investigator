---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Section from '../components/ui/Section.astro';
import Hero from '../components/ui/Hero.astro';
import TearsheetMockup from '../components/TearsheetMockup.astro';
import { Image } from 'astro:assets';
import appScreenshot from '../assets/images/homepage/app-screenshot.png';
import { getCollection } from 'astro:content';

// Fetch featured articles for homepage
const allReports = await getCollection('reports');
const featuredReports = allReports
  .filter(report => !report.id.startsWith('_')) // Exclude template files
  .filter(report => report.data.featured === true)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);
---

<Layout
  title="Fund Investigator - Comprehensive Mutual Fund Analysis"
  description="Detailed performance metrics and risk analysis for AMFI-registered funds. Data-driven insights to support your investment decisions."
>
  <!-- Hero Section -->
  <Hero size="md">
    <!-- Oversized heading with breathing room -->
    <div class="mb-16">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-display-xl font-bold text-navy mb-8 leading-[1.1] tracking-tight break-words">
        Mutual Fund Performance,
        <span class="text-navy/60">Made Clear</span>
      </h1>

      <!-- Reduced subtitle - single line, essential info only -->
      <p class="text-body-lg text-secondary-gray max-w-2xl mx-auto font-light leading-relaxed">
        Indian mutual funds are sold on marketing. We judge them with <strong>data</strong>.<br />
        Read our <strong>investigations</strong>, use our tools, and uncover the full picture yourself.
      </p>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-6 px-4">
      <Button href="/reports" size="lg" icon="arrow-right" class="w-full sm:w-auto">
        <span class="hidden sm:inline">Browse Investigations</span>
        <span class="sm:hidden">Investigations</span>
      </Button>
      <Button href="https://deepdive.fundinvestigator.com" variant="secondary" size="lg" icon="arrow-right" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto">
        <span class="hidden sm:inline">Investigate Yourself</span>
        <span class="sm:hidden">Try Deepdive</span>
      </Button>
    </div>

    <!-- Beginner's guide link -->
    <p class="text-body-sm text-secondary-gray text-center mb-0">
      New to mutual funds? <a href="#" class="text-gold underline hover:text-navy transition-colors">Start with our beginner's guide &rarr;</a>
    </p>
  </Hero>

  <!-- Problem Section: The Sales Trap -->
  <Section background="white" spacing="md" maxWidth="full">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="bg-gradient-to-br from-red-50/60 to-orange-50/40 rounded-2xl sm:rounded-3xl p-6 sm:p-8 lg:p-16">

        <!-- Section Header -->
        <div class="text-center mb-12 lg:mb-16">
          <Badge class="mb-6">The Sales Trap</Badge>
          <h2 class="text-3xl sm:text-4xl lg:text-display-md font-bold text-navy mb-6 leading-tight tracking-tight">
            Funds are marketed on their best returns.<br />
            <span class="text-navy/60">Your SIP statement tells a different story.</span>
          </h2>
          <p class="text-body-lg text-secondary-gray max-w-2xl mx-auto font-light leading-relaxed">
            Every fund has a story. The data tells you whether to believe it.
          </p>
        </div>

        <!-- Problem Cards Grid -->
        <div class="grid md:grid-cols-3 gap-6 lg:gap-8">

          <!-- Card 1: Returns are marketed -->
          <div class="bg-white rounded-2xl p-6 lg:p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-navy/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
            </div>
            <h3 class="text-heading-sm font-bold text-navy mb-3">Returns are marketed. Risk is footnoted.</h3>
            <p class="text-body-sm text-secondary-gray leading-relaxed">
              Past returns are marketed everywhere. Rolling returns and risk-adjusted metrics are hard to find. What you don't see is exactly what you need to make an informed decision.
            </p>
          </div>

          <!-- Card 2: Today's winner -->
          <div class="bg-white rounded-2xl p-6 lg:p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-navy/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
            </div>
            <h3 class="text-heading-sm font-bold text-navy mb-3">Today's winner is tomorrow's trap.</h3>
            <p class="text-body-sm text-secondary-gray leading-relaxed">
              Rankings reward recent performance. A fund that topped last year's charts may have simply caught a rising market. Past returns, without context, are a trap disguised as a signal.
            </p>
          </div>

          <!-- Card 3: Transparency -->
          <div class="bg-white rounded-2xl p-6 lg:p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-navy/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/>
              </svg>
            </div>
            <h3 class="text-heading-sm font-bold text-navy mb-3">Transparency doesn't earn commissions.</h3>
            <p class="text-body-sm text-secondary-gray leading-relaxed">
              Distributors earn trail commissions. Platforms earn referral fees. The fund that gets recommended is rarely the one that deserves it.
            </p>
          </div>

        </div>
      </div>
    </div>
  </Section>

  <!-- Investigations Section -->
  <Section background="white" spacing="md" maxWidth="full">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="bg-gradient-to-br from-blue-50 to-teal-50 rounded-2xl sm:rounded-3xl p-4 sm:p-8 lg:p-16">
        <div class="grid lg:grid-cols-[1fr,1.2fr] gap-8 lg:gap-12 items-start">
          <!-- Left: Description -->
          <div class="space-y-6 lg:sticky lg:top-32">
            <Badge class="mb-2">Investigations</Badge>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-navy break-words">What the Data Actually Says</h2>
            <p class="text-body-md text-secondary-gray leading-relaxed">
              Every fund analysed through three lenses — returns, risk, and risk-adjusted performance — across multiple time periods, against its stated investment objective.
            </p>
            <div>
              <Button href="/reports" variant="secondary" size="md">See all investigations</Button>
            </div>
          </div>

          <!-- Right: Featured investigation cards -->
          <div class="space-y-4">
            {featuredReports.length > 0 ? (
              featuredReports.map((report) => (
                <a href={`/reports/${report.slug}`} class="block group">
                  <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-6 shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100">
                    <div class="flex items-start justify-between gap-3 sm:gap-4">
                      <div class="flex-1 min-w-0">
                        <Badge class="mb-2">Featured Investigation</Badge>
                        <h3 class="text-base sm:text-lg font-bold text-navy mb-2 leading-tight group-hover:text-gold transition-colors break-words">
                          {report.data.title}
                        </h3>
                        <p class="text-sm sm:text-base text-secondary-gray leading-relaxed line-clamp-2">
                          {report.data.description}
                        </p>
                      </div>
                      <svg class="w-4 h-4 sm:w-5 sm:h-5 text-navy group-hover:text-gold transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </div>
                  </div>
                </a>
              ))
            ) : (
              <div class="bg-white rounded-2xl p-6 sm:p-8 text-center border border-gray-100">
                <p class="text-body-md text-secondary-gray">No featured investigations yet. Check back soon.</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Deepdive Showcase Section -->
  <Section background="white" spacing="md" maxWidth="full">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="bg-cream/50 rounded-2xl sm:rounded-3xl p-6 sm:p-12 lg:p-16">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Description -->
          <div class="space-y-6">
            <div>
              <Badge class="mb-4">OUR FEATURED DEEPDIVE APP</Badge>
              <h2 class="text-display-md font-bold text-navy">Your Own Fund Investigation</h2>
            </div>
            <p class="text-body-md text-secondary-gray leading-relaxed">
              Your analysis and imagination on our platform. Choose the fund, the benchmark, the time period and be the investigator.
            </p>
            <div class="space-y-4">
              <div class="flex gap-3">
                <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/>
                  <circle cx="12" cy="12" r="10" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p class="text-body-sm text-secondary-gray">Did your fund actually outperform — or did it just ride a bull market? Rolling and SIP returns tell you.</p>
              </div>
              <div class="flex gap-3">
                <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/>
                  <circle cx="12" cy="12" r="10" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p class="text-body-sm text-secondary-gray">How bad did it get? Drawdown analysis and max loss scenarios across real market cycles.</p>
              </div>
              <div class="flex gap-3">
                <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/>
                  <circle cx="12" cy="12" r="10" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p class="text-body-sm text-secondary-gray">Is the return worth the risk? Sharpe, Sortino, and benchmark correlation give you the answer.</p>
              </div>
            </div>
            <div>
              <Button href="https://deepdive.fundinvestigator.com" variant="primary" size="md" target="_blank" rel="noopener noreferrer">Launch Deepdive →</Button>
            </div>
          </div>

          <!-- Right: App Screenshot -->
          <div class="relative">
            <div class="aspect-[4/3] bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-200">
              <Image
                src={appScreenshot}
                alt="Deepdive app showing mutual fund performance metrics and charts"
                class="w-full h-full object-cover"
                loading="eager"
                widths={[640, 1024, 1400]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Why Fund Investigator Section -->
  <Section id="about" background="white" spacing="md" maxWidth="full" class="scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="bg-gradient-to-br from-navy/5 to-gold/5 rounded-2xl sm:rounded-3xl p-6 sm:p-12 lg:p-16">
        <div class="max-w-4xl mx-auto">
          <!-- Section Header -->
          <div class="text-center mb-12">
            <Badge class="mb-6">Why Fund Investigator</Badge>
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-6 leading-tight tracking-tight">
              Because Indian mutual fund investors deserve analysis that increases their returns.
              <span class="text-navy/60">Not mis-selling that increases someone else's commission.</span>
            </h2>
          </div>

          <!-- Key Points Grid -->
          <div class="grid md:grid-cols-3 gap-8 mb-16">
            <div class="text-center space-y-3">
              <div class="flex justify-center">
                <div class="w-14 h-14 bg-navy/10 rounded-2xl flex items-center justify-center">
                  <!-- line-chart -->
                  <svg class="w-7 h-7 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l4-8 4 5 5-6"/>
                  </svg>
                </div>
              </div>
              <h3 class="text-heading-sm font-bold text-navy">Analytics, Not Sales</h3>
              <p class="text-body-sm text-secondary-gray leading-relaxed">
                Every other mutual fund platform exists to complete a transaction. We exist to complete your analysis. No buy buttons, no portfolio nudges, no recommended funds.
              </p>
            </div>

            <div class="text-center space-y-3">
              <div class="flex justify-center">
                <div class="w-14 h-14 bg-navy/10 rounded-2xl flex items-center justify-center">
                  <!-- shield-check -->
                  <svg class="w-7 h-7 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/>
                  </svg>
                </div>
              </div>
              <h3 class="text-heading-sm font-bold text-navy">Zero Conflicts of Interest</h3>
              <p class="text-body-sm text-secondary-gray leading-relaxed">
                No commissions, no fund partnerships, no trail fees. The reason we can be pure analytics is because we don't earn from your decisions.
              </p>
            </div>

            <div class="text-center space-y-3">
              <div class="flex justify-center">
                <div class="w-14 h-14 bg-navy/10 rounded-2xl flex items-center justify-center">
                  <!-- eye -->
                  <svg class="w-7 h-7 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
              <h3 class="text-heading-sm font-bold text-navy">Transparent Methodology</h3>
              <p class="text-body-sm text-secondary-gray leading-relaxed">
                AMFI data, standard financial measures, clear calculations. No black boxes, no star ratings. Because some things shouldn't be simplified — they should be understood.
              </p>
            </div>
          </div>

          <!-- Link to About page -->
          <div class="text-center mt-12 pt-8 border-t border-gray-200">
            <a href="/about" class="text-navy hover:text-gold transition-colors text-body-sm font-medium inline-flex items-center gap-2">
              Read why we built this
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

        </div>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
