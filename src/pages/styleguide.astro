        <pre class="mt-4 bg-fi-dark text-fi-muted-inv p-4 rounded-xl text-body-sm overflow-x-auto"><code>{`<div class="w-11 h-11 bg-fi-icon-bg-inv rounded-xl
     flex items-center justify-center">
  <svg class="w-fi-icon h-fi-icon text-fi-muted-inv" .../>
</div>`}</code></pre>
      </div>
    </div>
  </Section>

  <!-- Layout Tokens -->
  <Section background="dark" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink-inv mb-2']}>Layout Tokens</h2>
    <p class="text-fi-muted-inv text-body-sm mb-10">Non-color tokens — spacing, sizing, shadows, z-index. All defined in <code class="text-fi-gold font-mono">tailwind.config.mjs</code>.</p>

    <div class="space-y-12">

      <!-- Shadows -->
      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-4">Shadows</h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-fi-light rounded-xl p-6 shadow-fi-card">
            <p class="text-sm font-mono text-fi-ink mb-1">shadow-fi-card</p>
            <p class="text-xs text-fi-muted">Card shadows on light sections — 0 4px 24px rgba(2,6,23,0.08)</p>
          </div>
          <div class="bg-fi-mid rounded-xl p-6 shadow-fi-card-dark">
            <p class="text-sm font-mono text-fi-ink-inv mb-1">shadow-fi-card-dark</p>
            <p class="text-xs text-fi-muted-inv">Card shadows on dark sections — 0 16px 44px rgba(0,0,0,0.30)</p>
          </div>
        </div>
      </div>

      <!-- Token Reference Table -->
      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-4">Token Reference</h3>
        <div class="bg-fi-mid border border-fi-border-dark rounded-xl overflow-hidden">
          <table class="w-full text-body-sm">
            <thead>
              <tr class="border-b border-fi-border-dark">
                <th class="text-left px-4 py-3 text-fi-muted-inv font-semibold">Category</th>
                <th class="text-left px-4 py-3 text-fi-muted-inv font-semibold">Token</th>
                <th class="text-left px-4 py-3 text-fi-muted-inv font-semibold">Value</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-fi-border-dark">
              <tr>
                <td class="px-4 py-3 text-fi-muted-inv" rowspan="3">Z-index</td>
                <td class="px-4 py-3 font-mono text-fi-gold">z-fi-header</td>
                <td class="px-4 py-3 text-fi-muted-inv">100 — sticky nav</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-mono text-fi-gold">z-fi-menu</td>
                <td class="px-4 py-3 text-fi-muted-inv">90 — mobile menu</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-mono text-fi-gold">z-fi-overlay</td>
                <td class="px-4 py-3 text-fi-muted-inv">80 — overlays</td>
              </tr>
              <tr>
                <td class="px-4 py-3 text-fi-muted-inv">Border radius</td>
                <td class="px-4 py-3 font-mono text-fi-gold">rounded-fi-btn</td>
                <td class="px-4 py-3 text-fi-muted-inv">10px — button corners</td>
              </tr>
              <tr>
                <td class="px-4 py-3 text-fi-muted-inv" rowspan="3">Spacing</td>
                <td class="px-4 py-3 font-mono text-fi-gold">px-fi-btn-x</td>
                <td class="px-4 py-3 text-fi-muted-inv">26px — button horizontal padding</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-mono text-fi-gold">px-fi-btn-x-sm</td>
                <td class="px-4 py-3 text-fi-muted-inv">18px — small button horizontal padding</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-mono text-fi-gold">py-fi-btn-y</td>
                <td class="px-4 py-3 text-fi-muted-inv">13px — button vertical padding</td>
              </tr>
              <tr>
                <td class="px-4 py-3 text-fi-muted-inv" rowspan="4">Sizing</td>
                <td class="px-4 py-3 font-mono text-fi-gold">w-fi-icon / h-fi-icon</td>
                <td class="px-4 py-3 text-fi-muted-inv">22px — card icons</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-mono text-fi-gold">w-fi-icon-lg / h-fi-icon-lg</td>
                <td class="px-4 py-3 text-fi-muted-inv">44px — touch targets (WCAG)</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-mono text-fi-gold">max-w-fi-content</td>
                <td class="px-4 py-3 text-fi-muted-inv">65ch — article prose reading width</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-mono text-fi-gold">--fi-header-h</td>
                <td class="px-4 py-3 text-fi-muted-inv">73px — CSS var for header height offset</td>
              </tr>
            </tbody>
