  </Section>

  <!-- Spacing -->
  <Section background="light" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink mb-8']}>Spacing Scale</h2>

    <div class="space-y-4 bg-white p-8 rounded-2xl border border-fi-border">
      <div class="flex items-center gap-4">
        <div class="w-32 text-sm font-mono text-fi-ink">tight-gap</div>
        <div class="h-4 bg-fi-dark rounded" style="width: 0.5rem;"></div>
        <div class="text-sm text-fi-muted">0.5rem / 8px</div>
      </div>
      <div class="flex items-center gap-4">
        <div class="w-32 text-sm font-mono text-fi-ink">element-gap</div>
        <div class="h-4 bg-fi-dark rounded" style="width: 1rem;"></div>
        <div class="text-sm text-fi-muted">1rem / 16px</div>
      </div>
      <div class="flex items-center gap-4">
        <div class="w-32 text-sm font-mono text-fi-ink">card-padding</div>
        <div class="h-4 bg-fi-dark rounded" style="width: 1.5rem;"></div>
        <div class="text-sm text-fi-muted">1.5rem / 24px</div>
      </div>
      <div class="flex items-center gap-4">
        <div class="w-32 text-sm font-mono text-fi-ink">card-gap</div>
        <div class="h-4 bg-fi-dark rounded" style="width: 2rem;"></div>
        <div class="text-sm text-fi-muted">2rem / 32px</div>
      </div>
      <div class="flex items-center gap-4">
        <div class="w-32 text-sm font-mono text-fi-ink">section-gap</div>
        <div class="h-4 bg-fi-dark rounded" style="width: 4rem;"></div>
        <div class="text-sm text-fi-muted">4rem / 64px</div>
      </div>
      <div class="flex items-center gap-4">
        <div class="w-32 text-sm font-mono text-fi-ink">section-y-sm</div>
        <div class="h-4 bg-fi-dark rounded" style="width: 5rem;"></div>
        <div class="text-sm text-fi-muted">5rem / 80px</div>
      </div>
      <div class="flex items-center gap-4">
        <div class="w-32 text-sm font-mono text-fi-ink">section-y</div>
        <div class="h-4 bg-fi-dark rounded" style="width: 8rem;"></div>
        <div class="text-sm text-fi-muted">8rem / 128px</div>
      </div>
    </div>
  </Section>

  <!-- Usage Guidelines -->
  <Section background="dark" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink-inv mb-8']}>Usage Guidelines</h2>

    <div class="max-w-3xl mx-auto space-y-6">
      <Card>
        <h3 class="text-heading-md text-fi-ink mb-4">Component Import</h3>
        <pre class="bg-gray-50 p-4 rounded-lg overflow-x-auto text-body-sm"><code>import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Section from '../components/ui/Section.astro';
import Hero from '../components/ui/Hero.astro';
import &#123; responsive &#125; from '../lib/responsive';</code></pre>
      </Card>

      <Card>
        <h3 class="text-heading-md text-fi-ink mb-4">Section Background Rhythm</h3>
        <table class="w-full text-body-sm">
          <thead>
            <tr class="border-b border-fi-border">
              <th class="text-left py-2 text-fi-ink font-semibold">Section</th>
              <th class="text-left py-2 text-fi-ink font-semibold">Background Prop</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-fi-border">
            <tr><td class="py-2 text-fi-muted">Hero</td><td class="py-2 font-mono text-body-sm">background="dark"</td></tr>
            <tr><td class="py-2 text-fi-muted">Problem / Deepdive / Email Capture</td><td class="py-2 font-mono text-body-sm">background="light"</td></tr>
            <tr><td class="py-2 text-fi-muted">Investigations / Why FI / Footer</td><td class="py-2 font-mono text-body-sm">background="dark"</td></tr>
          </tbody>
        </table>
      </Card>

      <Card>
        <h3 class="text-heading-md text-fi-ink mb-4">Color Usage Rules</h3>
        <ul class="space-y-2 text-fi-muted">
          <li><strong class="text-fi-ink">fi-ink / fi-muted:</strong> Text on light sections</li>
          <li><strong class="text-fi-ink">fi-ink-inv / fi-muted-inv:</strong> Text on dark sections</li>
          <li><strong class="text-fi-ink">fi-gold:</strong> Brand accent, buttons, H1 emphasis word on dark</li>
          <li><strong class="text-fi-ink">fi-positive / fi-negative / fi-neutral:</strong> Data visualization only</li>
          <li><strong class="text-fi-ink">success / warning / error / info:</strong> UI feedback states only</li>
        </ul>
      </Card>

      <Card>
        <h3 class="text-heading-md text-fi-ink mb-4">Button Hierarchy</h3>
        <ul class="space-y-2 text-fi-muted">
          <li><strong class="text-fi-ink">Primary:</strong> Main action on a page (e.g., "Launch Tool")</li>
          <li><strong class="text-fi-ink">Secondary:</strong> Important but not primary (e.g., "Learn More")</li>
          <li><strong class="text-fi-ink">Tertiary:</strong> Low emphasis links (e.g., "View All")</li>
          <li><strong class="text-fi-ink">Outline:</strong> Special emphasis with gold accent</li>
        </ul>
      </Card>

      <Card>
        <h3 class="text-heading-md text-fi-ink mb-4">Grid Rules</h3>
        <ul class="space-y-2 text-fi-muted">
          <li>Never jump from 1-col to 3-col — always use <code class="font-mono text-body-sm">sm:grid-cols-2 lg:grid-cols-3</code></li>
          <li>Section horizontal padding owned by <strong class="text-fi-ink">Section.astro</strong> — never add manually</li>
          <li>Use <code class="font-mono text-body-sm">maxWidth="2xl"</code> for standard homepage sections</li>
          <li>Never combine <code class="font-mono text-body-sm">maxWidth="full"</code> with a manual inner container</li>
        </ul>
      </Card>
    </div>
  </Section>
</Layout>
