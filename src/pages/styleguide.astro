---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Section from '../components/ui/Section.astro';
import Hero from '../components/ui/Hero.astro';
import { responsive } from '../lib/responsive';
---

<Layout
  title="Design System - Fund Investigator"
  description="Component library and design tokens for Fund Investigator"
>
  <!-- Hero -->
  <Hero size="md">
    <h1 class:list={[responsive.display, 'font-bold text-fi-ink-inv mb-4']}>Design System</h1>
    <p class="text-body-lg text-fi-muted-inv max-w-2xl mx-auto">
      Component library, design tokens, and usage guidelines for Fund Investigator.
      Homepage uses <code class="text-fi-gold font-mono text-sm">size="lg"</code>.
    </p>
  </Hero>

  <!-- Color Palette -->
  <Section background="light" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink mb-8']}>Color Palette</h2>

    <div class="space-y-12">

      <!-- Structural Backgrounds -->
      <div>
        <h3 class="text-heading-md text-fi-ink mb-2">Structural Backgrounds</h3>
        <p class="text-fi-muted text-body-sm mb-6">Section-level backgrounds — alternate dark/light across the page.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="space-y-2">
            <div class="h-24 bg-fi-dark rounded-lg border border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">bg-fi-dark</p>
            <p class="text-xs text-fi-muted">Hero · Investigations · Why FI · Footer</p>
          </div>
          <div class="space-y-2">
            <div class="h-24 bg-fi-mid rounded-lg border border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">bg-fi-mid</p>
            <p class="text-xs text-fi-muted">Card surfaces on dark · Label pill bg</p>
          </div>
          <div class="space-y-2">
            <div class="h-24 bg-fi-light rounded-lg border border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">bg-fi-light</p>
            <p class="text-xs text-fi-muted">Problem · Deepdive · Email Capture</p>
          </div>
        </div>
      </div>

      <!-- Semantic Text & UI -->
      <div>
        <h3 class="text-heading-md text-fi-ink mb-2">Semantic Text &amp; UI</h3>
        <p class="text-fi-muted text-body-sm mb-6">Never use raw hex or arbitrary values — always reference these tokens.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Light bg text -->
          <div class="space-y-2">
            <div class="h-16 bg-fi-ink rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-ink</p>
            <p class="text-xs text-fi-muted">Primary text on light bg</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-muted rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-muted</p>
            <p class="text-xs text-fi-muted">Secondary text on light bg</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-gold rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-gold / bg-fi-gold</p>
            <p class="text-xs text-fi-muted">Brand accent · CTAs · H1 emphasis on dark</p>
          </div>
          <!-- Dark bg text -->
          <div class="space-y-2">
            <div class="h-16 bg-fi-ink-inv rounded-lg border border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-ink-inv</p>
            <p class="text-xs text-fi-muted">Primary text on dark bg</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-muted-inv rounded-lg border border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-muted-inv</p>
            <p class="text-xs text-fi-muted">Secondary text on dark bg</p>
          </div>
          <!-- Borders & Icon BGs -->
          <div class="space-y-2">
            <div class="h-16 bg-fi-border rounded-lg border-2 border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">border-fi-border</p>
            <p class="text-xs text-fi-muted">Borders on light sections</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-border-dark rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">border-fi-border-dark</p>
            <p class="text-xs text-fi-muted">Borders on dark sections</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-icon-bg rounded-lg border border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">bg-fi-icon-bg</p>
            <p class="text-xs text-fi-muted">Icon container on light bg</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-icon-bg-inv rounded-lg border border-fi-border"></div>
            <p class="text-sm font-mono text-fi-ink">bg-fi-icon-bg-inv</p>
            <p class="text-xs text-fi-muted">Icon container on dark bg</p>
          </div>
        </div>
      </div>

      <!-- Data Visualization Colors -->
      <div>
        <h3 class="text-heading-md text-fi-ink mb-2">Data Visualization</h3>
        <p class="text-fi-muted text-body-sm mb-6">For performance metrics, tables, and chart annotations.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="space-y-2">
            <div class="h-16 bg-fi-positive rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-positive</p>
            <p class="text-xs text-fi-muted">Positive performance · emerald-500</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-negative rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-negative</p>
            <p class="text-xs text-fi-muted">Negative performance · red-500</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-fi-neutral rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">text-fi-neutral</p>
            <p class="text-xs text-fi-muted">Neutral / unchanged · slate-500</p>
          </div>
        </div>
      </div>

      <!-- Semantic Colors -->
      <div>
        <h3 class="text-heading-md text-fi-ink mb-2">Semantic Colors</h3>
        <p class="text-fi-muted text-body-sm mb-6">UI feedback states — forms, alerts, validation.</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          <div class="space-y-2">
            <div class="h-16 bg-success rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">success</p>
            <p class="text-xs text-fi-muted">#10b981</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-warning rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">warning</p>
            <p class="text-xs text-fi-muted">#f59e0b</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-error rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">error</p>
            <p class="text-xs text-fi-muted">#ef4444</p>
          </div>
          <div class="space-y-2">
            <div class="h-16 bg-info rounded-lg"></div>
            <p class="text-sm font-mono text-fi-ink">info</p>
            <p class="text-xs text-fi-muted">#3b82f6</p>
          </div>
        </div>
      </div>

    </div>
  </Section>

  <!-- Typography -->
  <Section background="dark" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink-inv mb-2']}>Typography</h2>
    <p class="text-fi-muted-inv text-body-sm mb-10">Use <code class="text-fi-gold font-mono">responsive.*</code> presets — never write breakpoint classes inline.</p>

    <!-- Responsive Presets (recommended) -->
    <div class="mb-12">
      <h3 class="text-heading-md text-fi-ink-inv mb-2">Responsive Presets</h3>
      <p class="text-fi-muted-inv text-body-sm mb-6">Import from <code class="text-fi-gold font-mono">src/lib/responsive.ts</code>. Each entry shows the class string it expands to.</p>

      <div class="space-y-6">
        <div class="bg-fi-mid border border-fi-border-dark rounded-xl p-6">
          <p class="text-caption text-fi-muted-inv mb-1 font-mono">responsive.display — Hero H1</p>
          <p class="text-caption text-fi-gold font-mono mb-4">'text-4xl sm:text-5xl md:text-6xl lg:text-display-xl'</p>
          <p class:list={[responsive.display, 'font-bold text-fi-ink-inv leading-tight']}>The quick brown fox</p>
        </div>

        <div class="bg-fi-mid border border-fi-border-dark rounded-xl p-6">
          <p class="text-caption text-fi-muted-inv mb-1 font-mono">responsive.h2Large — Section headings</p>
          <p class="text-caption text-fi-gold font-mono mb-4">'text-heading-lg sm:text-heading-xl lg:text-display-md'</p>
          <p class:list={[responsive.h2Large, 'font-bold text-fi-ink-inv']}>The quick brown fox</p>
        </div>

        <div class="bg-fi-mid border border-fi-border-dark rounded-xl p-6">
          <p class="text-caption text-fi-muted-inv mb-1 font-mono">responsive.h2 — Sub-section headings</p>
          <p class="text-caption text-fi-gold font-mono mb-4">'text-heading-md sm:text-heading-lg lg:text-heading-xl'</p>
          <p class:list={[responsive.h2, 'font-bold text-fi-ink-inv']}>The quick brown fox jumps</p>
        </div>

        <div class="bg-fi-mid border border-fi-border-dark rounded-xl p-6">
          <p class="text-caption text-fi-muted-inv mb-1 font-mono">responsive.h3 — Subsection headings</p>
          <p class="text-caption text-fi-gold font-mono mb-4">'text-heading-sm sm:text-heading-md'</p>
          <p class:list={[responsive.h3, 'font-bold text-fi-ink-inv']}>The quick brown fox jumps over</p>
        </div>

        <div class="bg-fi-mid border border-fi-border-dark rounded-xl p-6">
          <p class="text-caption text-fi-muted-inv mb-1 font-mono">responsive.subtitle — Lead / subtitle text</p>
          <p class="text-caption text-fi-gold font-mono mb-4">'text-body-md sm:text-body-lg'</p>
          <p class:list={[responsive.subtitle, 'text-fi-muted-inv']}>The quick brown fox jumps over the lazy dog.</p>
        </div>
      </div>
    </div>

    <!-- Raw Scale -->
    <div>
      <h3 class="text-heading-md text-fi-ink-inv mb-2">Raw Scale</h3>
      <p class="text-fi-muted-inv text-body-sm mb-6">Reference only — use <code class="text-fi-gold font-mono">responsive.*</code> presets in production.</p>

      <div class="space-y-6 bg-fi-mid border border-fi-border-dark p-8 rounded-2xl">
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-display-xl</p>
          <p class="text-display-xl text-fi-ink-inv">The quick brown fox</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-display-lg</p>
          <p class="text-display-lg text-fi-ink-inv">The quick brown fox</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-display-md</p>
          <p class="text-display-md text-fi-ink-inv">The quick brown fox</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-heading-xl</p>
          <p class="text-heading-xl text-fi-ink-inv">The quick brown fox jumps</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-heading-lg</p>
          <p class="text-heading-lg text-fi-ink-inv">The quick brown fox jumps over</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-heading-md</p>
          <p class="text-heading-md text-fi-ink-inv">The quick brown fox jumps over the lazy</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-heading-sm</p>
          <p class="text-heading-sm text-fi-ink-inv">The quick brown fox jumps over the lazy dog</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-body-lg</p>
          <p class="text-body-lg text-fi-muted-inv">The quick brown fox jumps over the lazy dog. This is body large text used for introductory paragraphs and emphasis.</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-body-md</p>
          <p class="text-body-md text-fi-muted-inv">The quick brown fox jumps over the lazy dog. This is body medium text used for standard paragraph content.</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-body-sm</p>
          <p class="text-body-sm text-fi-muted-inv">The quick brown fox jumps over the lazy dog. Body small for secondary content, captions, and metadata.</p>
        </div>
        <div>
          <p class="text-caption text-fi-muted-inv mb-2 font-mono">text-caption</p>
          <p class="text-caption text-fi-muted-inv">THE QUICK BROWN FOX JUMPS OVER THE LAZY DOG</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Buttons -->
  <Section background="light" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink mb-8']}>Buttons</h2>

    <div class="space-y-12">
      <div>
        <h3 class="text-heading-md text-fi-ink mb-6">Variants</h3>
        <div class="flex flex-wrap gap-4">
          <Button variant="primary">Primary Button</Button>
          <Button variant="secondary">Secondary Button</Button>
          <Button variant="tertiary">Tertiary Button</Button>
          <Button variant="outline">Outline Button</Button>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink mb-6">Sizes</h3>
        <div class="flex flex-wrap items-center gap-4">
          <Button size="sm">Small</Button>
          <Button size="md">Medium</Button>
          <Button size="lg">Large</Button>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink mb-6">With Icons</h3>
        <div class="flex flex-wrap gap-4">
          <Button icon="arrow-right">Launch Tool</Button>
          <Button variant="secondary" icon="external">View Report</Button>
          <Button variant="tertiary" icon="arrow-right">Read More</Button>
          <Button variant="outline" icon="download">Download</Button>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink mb-6">States</h3>
        <div class="flex flex-wrap gap-4">
          <Button>Normal</Button>
          <Button disabled>Disabled</Button>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink mb-6">Full Width</h3>
        <Button fullWidth>Full Width Button</Button>
      </div>
    </div>
  </Section>

  <!-- Badges -->
  <Section background="dark" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink-inv mb-8']}>Badges</h2>

    <div class="space-y-8">
      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-2">Light Background Variants</h3>
        <p class="text-fi-muted-inv text-body-sm mb-4">Use <code class="text-fi-gold font-mono">variant="default"</code> (or omit) on <code class="text-fi-gold font-mono">background="light"</code> sections.</p>
        <div class="bg-fi-light rounded-xl p-6 flex flex-wrap gap-3">
          <Badge>Default</Badge>
          <Badge variant="primary">Primary</Badge>
          <Badge variant="secondary">Secondary</Badge>
          <Badge variant="success">Success</Badge>
          <Badge variant="warning">Warning</Badge>
          <Badge variant="error">Error</Badge>
          <Badge variant="info">Info</Badge>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-2">Dark Background Variant</h3>
        <p class="text-fi-muted-inv text-body-sm mb-4">Use <code class="text-fi-gold font-mono">variant="dark"</code> on <code class="text-fi-gold font-mono">background="dark"</code> sections — section labels on hero, investigations, why FI.</p>
        <div class="bg-fi-dark border border-fi-border-dark rounded-xl p-6 flex flex-wrap gap-3">
          <Badge variant="dark">Investigations</Badge>
          <Badge variant="dark">Why FI</Badge>
          <Badge variant="dark">Section Label</Badge>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-4">Sizes</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Badge variant="dark" size="sm">Small</Badge>
          <Badge variant="dark" size="md">Medium</Badge>
          <Badge variant="dark" size="lg">Large</Badge>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-4">Corner Styles</h3>
        <div class="flex flex-wrap gap-3">
          <Badge variant="dark" rounded={true}>Pill Shape</Badge>
          <Badge variant="dark" rounded={false}>Rounded Corners</Badge>
        </div>
      </div>
    </div>
  </Section>

  <!-- Section Header Pattern -->
  <Section background="light" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink mb-2']}>Section Header Pattern</h2>
    <p class="text-fi-muted text-body-sm mb-10">Standard composite used across homepage sections — Badge + H2 + subtitle.</p>

    <div class="space-y-8">
      <!-- On Light -->
      <div>
        <h3 class="text-heading-md text-fi-ink mb-4">On Light Background</h3>
        <div class="bg-fi-light rounded-xl p-8">
          <Badge>Section Label</Badge>
          <h2 class:list={[responsive.h2Large, 'text-fi-ink mt-4 mb-4']}>Section Heading Goes Here</h2>
          <p class="text-fi-muted text-body-lg max-w-2xl">Supporting subtitle that provides context. Keep to one or two sentences — let the content sections carry the detail.</p>
        </div>
        <pre class="mt-4 bg-fi-dark text-fi-muted-inv p-4 rounded-xl text-body-sm overflow-x-auto"><code>{`<Badge>Section Label</Badge>
<h2 class:list={[responsive.h2Large, 'text-fi-ink mt-4 mb-4']}>Section Heading</h2>
<p class="text-fi-muted text-body-lg max-w-2xl">Supporting subtitle text.</p>`}</code></pre>
      </div>

      <!-- On Dark -->
      <div>
        <h3 class="text-heading-md text-fi-ink mb-4">On Dark Background</h3>
        <div class="bg-fi-dark rounded-xl p-8">
          <Badge variant="dark">Section Label</Badge>
          <h2 class:list={[responsive.h2Large, 'text-fi-ink-inv mt-4 mb-4']}>Section Heading Goes Here</h2>
          <p class="text-fi-muted-inv text-body-lg max-w-2xl">Supporting subtitle that provides context. Keep to one or two sentences — let the content sections carry the detail.</p>
        </div>
        <pre class="mt-4 bg-fi-dark text-fi-muted-inv p-4 rounded-xl text-body-sm overflow-x-auto"><code>{`<Badge variant="dark">Section Label</Badge>
<h2 class:list={[responsive.h2Large, 'text-fi-ink-inv mt-4 mb-4']}>Section Heading</h2>
<p class="text-fi-muted-inv text-body-lg max-w-2xl">Supporting subtitle text.</p>`}</code></pre>
      </div>
    </div>
  </Section>

  <!-- Cards -->
  <Section background="dark" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink-inv mb-8']}>Cards</h2>

    <div class="space-y-8">
      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-4">Variants</h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <Card>
            <h3 class="text-heading-md text-fi-ink mb-2">Default Card</h3>
            <p class="text-fi-muted">Standard card with border and hover effect.</p>
          </Card>
          <Card variant="elevated">
            <h3 class="text-heading-md text-fi-ink mb-2">Elevated Card</h3>
            <p class="text-fi-muted">Card with <code class="font-mono text-body-sm">shadow-fi-card</code> and enhanced hover.</p>
          </Card>
          <Card variant="bordered">
            <h3 class="text-heading-md text-fi-ink mb-2">Bordered Card</h3>
            <p class="text-fi-muted">Prominent border with minimal shadow.</p>
          </Card>
          <Card variant="glass">
            <h3 class="text-heading-md text-fi-ink mb-2">Glass Card</h3>
            <p class="text-fi-muted">Semi-transparent with backdrop blur.</p>
          </Card>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-4">Padding Variants</h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <Card padding="sm">
            <h4 class="text-heading-sm text-fi-ink mb-1">Small Padding</h4>
            <p class="text-sm text-fi-muted">Compact card content</p>
          </Card>
          <Card padding="lg">
            <h4 class="text-heading-sm text-fi-ink mb-2">Large Padding</h4>
            <p class="text-fi-muted">More spacious card content</p>
          </Card>
        </div>
      </div>

      <div>
        <h3 class="text-heading-md text-fi-ink-inv mb-4">Without Hover</h3>
        <Card hover={false}>
          <h4 class="text-heading-sm text-fi-ink mb-2">Static Card</h4>
          <p class="text-fi-muted">This card does not have hover effects.</p>
        </Card>
      </div>
    </div>
  </Section>

  <!-- Icon Container Pattern -->
  <Section background="light" spacing="lg">
    <h2 class:list={[responsive.h2, 'text-fi-ink mb-2']}>Icon Container Pattern</h2>
    <p class="text-fi-muted text-body-sm mb-10">Standard icon container used in feature cards and benefit lists. Use <code class="font-mono">fi-icon</code> (22px) for card icons, <code class="font-mono">fi-icon-lg</code> (44px) for touch targets (footer socials, etc.).</p>

    <div class="grid sm:grid-cols-2 gap-8">
      <!-- On Light -->
      <div>
        <h3 class="text-heading-md text-fi-ink mb-4">On Light Background (<code class="font-mono text-body-sm">bg-fi-icon-bg</code>)</h3>
        <div class="bg-fi-light rounded-xl p-8 flex gap-4">
          <div class="w-11 h-11 bg-fi-icon-bg rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-fi-icon h-fi-icon text-fi-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <p class="text-heading-sm text-fi-ink">Feature Title</p>
            <p class="text-fi-muted text-body-sm">Supporting description text.</p>
          </div>
        </div>
        <pre class="mt-4 bg-fi-dark text-fi-muted-inv p-4 rounded-xl text-body-sm overflow-x-auto"><code>{`<div class="w-11 h-11 bg-fi-icon-bg rounded-xl
     flex items-center justify-center">
  <svg class="w-fi-icon h-fi-icon text-fi-muted" .../>
</div>`}</code></pre>
      </div>

