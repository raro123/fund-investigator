---
/**
 * Badge Component
 *
 * A small label component for categories, tags, and status indicators.
 *
 * @example
 * <!-- Default cream badge -->
 * <Badge>Fund Analysis</Badge>
 *
 * <!-- Primary navy badge -->
 * <Badge variant="primary">Active</Badge>
 *
 * <!-- Success badge -->
 * <Badge variant="success" size="sm">Completed</Badge>
 */

interface Props {
  /** Badge color variant */
  variant?: 'default' | 'dark' | 'primary' | 'secondary' | 'success' | 'warning' | 'error' | 'info';
  /** Badge size */
  size?: 'sm' | 'md' | 'lg';
  /** Use rounded corners instead of pill shape */
  rounded?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const {
  variant = 'default',
  size = 'md',
  rounded = true,
  class: className = '',
} = Astro.props;

// Variant styles
const variantStyles = {
  default:   'bg-fi-icon-bg border border-fi-border text-fi-muted',       // light sections
  dark:      'bg-fi-mid border border-fi-border-dark text-fi-muted-inv',  // dark sections
  primary:   'bg-fi-dark text-fi-ink-inv',
  secondary: 'bg-gray-100 text-gray-700',
  success:   'bg-fi-positive/20 text-fi-positive',
  warning:   'bg-amber-100 text-amber-700',
  error:     'bg-fi-negative/20 text-fi-negative',
  info:      'bg-blue-100 text-blue-700',
};

// Size styles
const sizeStyles = {
  sm: 'px-2 py-0.5 text-caption',
  md: 'px-3 py-1.5 text-caption',
  lg: 'px-4 py-1.5 text-xs',
};

// Border radius
const roundedStyles = rounded ? 'rounded-full' : 'rounded';

// Base styles — uppercase + tracking per spec
const baseStyles = 'inline-block font-bold uppercase tracking-[0.13em]';

// Combined classes
const classes = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${roundedStyles} ${className}`.trim();
---

<span class={classes}>
  <slot />
</span>
